# =============================================================
# stock.quanganh.org — Vercel production environment
# =============================================================
# These values match what should be set in the Vercel dashboard.
# Non-secret public endpoints are committed here as documentation
# and for local `next build` testing.
#
# Domain architecture:
#   stock.quanganh.org  → Vercel (this Next.js app)
#   api.quanganh.org    → VPS nginx gateway (Flask :8000, PM2 :3001/:3000)
#
# Traffic flow:
#   REST : browser → /api/* → Next.js proxy (route.ts) → BACKEND_API_URL
#   WS   : browser → wss://api.quanganh.org/… (direct, Vercel has no WS proxy)
# =============================================================

# ── Server-side (Next.js proxy in /app/api/[...path]/route.ts) ──────────
# Production backend base URL (Flask on VPS via nginx)
BACKEND_API_URL=https://api.quanganh.org/v1/valuation

# ── Client-side (browser) ────────────────────────────────────────────────
# REST: leave unset to use same-origin /api proxy through Vercel (default)
# NEXT_PUBLIC_API_URL=

# WebSocket: must point directly to VPS — Vercel does not proxy WebSockets
NEXT_PUBLIC_BACKEND_WS_URL=wss://api.quanganh.org/v1/valuation
